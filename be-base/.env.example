# App
NODE_ENV=development
PORT=3000
JWT_ACCESS_SECRET=change-me-in-production

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/be_base"

# CORS
CORS_ORIGIN=http://localhost:5173

# Seed admin đầu tiên (chỉ chạy nếu email chưa tồn tại trong DB)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me-immediately
ADMIN_SEED_ROLE=super-admin

# Docker (dùng cho docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=be_base
